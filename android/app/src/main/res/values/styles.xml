<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Theme áp dụng trong khi Android đang khởi động process.
         windowBackground được show ngay lập tức trước khi Flutter engine sẵn sàng.
         Đặt màu xanh giống splash Flutter để không có hiệu ứng nhấp nháy màu. -->
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowFullscreen">true</item>
    </style>

    <!-- Theme áp dụng ngay sau khi process khởi động xong,
         trong khi Flutter UI đang khởi tạo. -->
    <style name="NormalTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">?android:colorBackground</item>
    </style>
</resources>
